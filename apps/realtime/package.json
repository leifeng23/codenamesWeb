{
  "name": "@cosmere/realtime",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "esbuild src/server.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/server.cjs --external:socket.io --external:ioredis --external:@socket.io/redis-adapter --external:zod --external:@prisma/client",
    "start": "node dist/server.cjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cosmere/shared": "file:../../packages/shared",
    "@socket.io/redis-adapter": "^8.3.0",
    "ioredis": "^5.4.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
